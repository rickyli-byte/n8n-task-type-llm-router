      "id": "11111111-0000-0000-0000-000000000002",
      "name": "Sample input (edit me)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-740, 240],
      "notes": "Change task_type to autonomous_agent / frontend / long_context / cheap_batch to see it route to a different model. context_tokens > 200000 also forces the long-context model."
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "outputKey": "agent",
              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
                "conditions": [
                  {
                    "id": "rule-agent",
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "autonomous_agent",
                    "operator": {"type": "string", "operation": "equals"}
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "outputKey": "frontend",
              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
                "conditions": [
                  {
                    "id": "rule-frontend",
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "frontend",
                    "operator": {"type": "string", "operation": "equals"}
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "outputKey": "long_context",
              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
                "conditions": [
                  {
                    "id": "rule-longctx-type",
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "long_context",
                    "operator": {"type": "string", "operation": "equals"}
                  },
                  {
                    "id": "rule-longctx-tokens",
                    "leftValue": "={{ $json.context_tokens }}",
                    "rightValue": 200000,
                    "operator": {"type": "number", "operation": "gt"}
                  }
                ],
                "combinator": "or"
              }
            },
            {
              "outputKey": "cheap_batch",
              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
                "conditions": [
                  {
                    "id": "rule-cheap",
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "cheap_batch",
                    "operator": {"type": "string", "operation": "equals"}
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {"fallbackOutput": "extra", "renameFallbackOutput": "fallback"}
      },
      "id": "11111111-0000-0000-0000-000000000003",
      "name": "Route by task type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [-500, 240],
      "notes": "autonomous_agent -> Kimi (long agent runs). frontend -> GLM (UI/code). long_context OR >200k tokens -> Qwen. cheap_batch -> MiniMax (cheapest). Anything else falls back to Kimi."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.atlascloud.ai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Content-Type", "value": "application/json"}]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"moonshotai/kimi-k2.6\",\n  \"messages\": [{\"role\": \"user\", \"content\": {{ JSON.stringify($json.prompt) }} }],\n  \"max_tokens\": 2048,\n  \"temperature\": 0.3\n}",
        "options": {"timeout": 120000}
      },
      "id": "11111111-0000-0000-0000-000000000004",
      "name": "Kimi K2.6 (agents)",
      "type": "n8n-nodes-base.httpRequest",
