        "jsonBody": "={\n  \"model\": \"zai-org/glm-5.1\",\n  \"messages\": [{\"role\": \"user\", \"content\": {{ JSON.stringify($json.prompt) }} }],\n  \"max_tokens\": 2048,\n  \"temperature\": 0.3\n}",
        "options": {"timeout": 120000}
      },
      "id": "11111111-0000-0000-0000-000000000005",
      "name": "GLM 5.1 (front-end)",
      "type": "n8n-nodes-base.httpRequest",
